# AI Events Intelligence Pipeline — Configuration

# --- API Keys ---
# Eventbrite API key for structured event discovery
# Get one at: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_KEY=

# OpenRouter API key for LLM-based event scoring
OPENROUTER_API_KEY=

# Brave Search API setup (via pi-skills brave-search)

# --- Geo-Filtering (London, Oxbridge, South East, and online) ---
# Centre point for geo-filtering (default: London)
LONDON_LAT=51.5074
LONDON_LNG=-0.1278
# Search radius in kilometres (default 100 covers London to Cambridge)
GEO_RADIUS_KM=100

# --- Discovery Configuration ---
# Number of Brave Search queries to use per pipeline run
MAX_QUERIES_PER_RUN=5
# Number of Brave results to fetch per query
BRAVE_RESULTS_PER_QUERY=15
# Comma-separated list of domains for Brave site: queries
BRAVE_DOMAIN_FILTERS=imperial.ac.uk,ucl.ac.uk,kcl.ac.uk,ox.ac.uk,cam.ac.uk,lse.ac.uk,qmul.ac.uk,rhul.ac.uk,surrey.ac.uk,reading.ac.uk,deepmind.google,eventbrite.co.uk,eventbrite.com

# --- Deep Crawl Configuration ---
# Comma-separated list of domains eligible for level-2 deep crawling
HIGHLY_SOURCED_DOMAINS=imperial.ac.uk,ucl.ac.uk,kcl.ac.uk,ox.ac.uk,cam.ac.uk,rhul.ac.uk,surrey.ac.uk,reading.ac.uk,qmul.ac.uk,lse.ac.uk,deepmind.google,eventbrite.co.uk,eventbrite.com
# Max sub-pages to deep-crawl per run
MAX_DEEP_CRAWL_PER_RUN=5
# Max sources to fetch per run
MAX_FETCHES_PER_RUN=5

# --- Rate Limiting ---
# Max API calls per pipeline run for structured discovery APIs
API_CALLS_PER_RUN=60
# Delay in seconds between API calls to the same platform
API_DELAY_SECONDS=0.5

# --- LLM Model ---
# Model used for event scoring (via OpenRouter)
MODEL_NAME=google/gemma-4-31b-it